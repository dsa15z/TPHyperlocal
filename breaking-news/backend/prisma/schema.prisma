generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Platform {
  FACEBOOK
  TWITTER
  RSS
  NEWSAPI
  GDELT
  LLM_OPENAI
  LLM_CLAUDE
  LLM_GROK
  LLM_GEMINI
  MANUAL
}

enum SourceType {
  NEWS_ORG
  GOV_AGENCY
  PUBLIC_PAGE
  RSS_FEED
  API_PROVIDER
  LLM_PROVIDER
}

enum StoryStatus {
  EMERGING
  BREAKING
  TRENDING
  ACTIVE
  STALE
  ARCHIVED
}

enum UserRole {
  VIEWER
  EDITOR
  ADMIN
  OWNER
}

// ─── Multi-Tenant: Account ─────────────────────────────────────────────────

model Account {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  isActive    Boolean  @default(true)
  plan        String   @default("free") // free, pro, enterprise
  maxMarkets  Int      @default(1)
  maxSources  Int      @default(20)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users          AccountUser[]
  markets        Market[]
  accountSources AccountSource[]
  credentials    AccountCredential[]
  apiKeys        APIKey[]
  feeds          RSSFeed[]
  auditLogs      AuditLog[]

  @@index([slug])
  @@index([isActive])
}

// ─── Multi-Tenant: Users & Auth ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  displayName   String?
  avatarUrl     String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  AccountUser[]
  auditLogs AuditLog[]

  @@index([email])
}

model AccountUser {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      UserRole @default(VIEWER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, userId])
  @@index([accountId])
  @@index([userId])
}

// ─── Multi-Tenant: Markets ──────────────────────────────────────────────────

model Market {
  id          String  @id @default(cuid())
  accountId   String
  account     Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name        String  // "Houston", "Dallas", "Austin"
  slug        String  // "houston", "dallas", "austin"
  state       String? // "TX"
  latitude    Float
  longitude   Float
  radiusKm    Float   @default(80)
  timezone    String  @default("America/Chicago")
  isActive    Boolean @default(true)
  // Market-specific keyword sets for filtering
  keywords    Json?   // ["houston", "harris county", "galveston"]
  neighborhoods Json? // ["Galleria", "Montrose", "Heights", ...]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sources Source[]
  stories Story[]

  @@unique([accountId, slug])
  @@index([accountId, isActive])
}

// ─── Multi-Tenant: Per-Account Credentials ──────────────────────────────────
// Each account stores their own API keys for external services

model AccountCredential {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platform    Platform
  name        String   // "NewsAPI Key", "OpenAI API Key", etc.
  // Encrypted credential fields
  apiKey      String?  @db.Text // encrypted at rest
  apiSecret   String?  @db.Text // encrypted at rest
  accessToken String?  @db.Text // encrypted at rest
  extraConfig Json?    // additional platform-specific config
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([accountId, platform, name])
  @@index([accountId, platform])
}

// ─── Multi-Tenant: Account-Source Configuration ─────────────────────────────
// Controls which sources are enabled for each account

model AccountSource {
  id             String   @id @default(cuid())
  accountId      String
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sourceId       String
  source         Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  isEnabled      Boolean  @default(true)
  pollIntervalMs Int?     // override default poll interval
  metadata       Json?    // account-specific source config
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([accountId, sourceId])
  @@index([accountId, isEnabled])
}

// ─── Sources ────────────────────────────────────────────────────────────────

model Source {
  id           String       @id @default(cuid())
  platform     Platform
  sourceType   SourceType
  name         String
  url          String?
  platformId   String?
  trustScore   Float        @default(0.5)
  isActive     Boolean      @default(true)
  isGlobal     Boolean      @default(false) // available to all accounts
  marketId     String?
  market       Market?      @relation(fields: [marketId], references: [id], onDelete: SetNull)
  metadata     Json?
  lastPolledAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  posts          SourcePost[]
  accountSources AccountSource[]

  @@index([platform, isActive])
  @@index([sourceType])
  @@index([marketId])
  @@index([isGlobal])
}

// ─── Source Posts ────────────────────────────────────────────────────────────

model SourcePost {
  id                 String   @id @default(cuid())
  sourceId           String
  source             Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  platformPostId     String   @unique
  content            String   @db.Text
  contentHash        String
  title              String?
  url                String?
  authorName         String?
  authorId           String?
  engagementLikes    Int      @default(0)
  engagementShares   Int      @default(0)
  engagementComments Int      @default(0)
  latitude           Float?
  longitude          Float?
  locationName       String?
  category           String?
  mediaUrls          Json?
  rawData            Json?
  // LLM-specific fields
  llmModel           String?  // "gpt-4o", "claude-sonnet-4-6", "grok-3", "gemini-2.0-flash"
  llmConfidence      Float?   // LLM's self-reported confidence 0-1
  publishedAt        DateTime
  collectedAt        DateTime @default(now())
  createdAt          DateTime @default(now())

  storySources StorySource[]

  @@index([platformPostId])
  @@index([contentHash])
  @@index([sourceId, publishedAt])
  @@index([category])
  @@index([publishedAt])
}

// ─── Stories ────────────────────────────────────────────────────────────────

model Story {
  id              String      @id @default(cuid())
  marketId        String?
  market          Market?     @relation(fields: [marketId], references: [id], onDelete: SetNull)
  title           String
  summary         String?     @db.Text
  aiSummary       String?     @db.Text // LLM-generated canonical summary
  category        String?
  locationName    String?
  latitude        Float?
  longitude       Float?
  neighborhood    String?
  breakingScore   Float       @default(0)
  trendingScore   Float       @default(0)
  confidenceScore Float       @default(0)
  localityScore   Float       @default(0)
  compositeScore  Float       @default(0)
  status          StoryStatus @default(EMERGING)
  sourceCount     Int         @default(0)
  firstSeenAt     DateTime    @default(now())
  lastUpdatedAt   DateTime    @default(now())
  mergedIntoId    String?
  mergedInto      Story?      @relation("StoryMerges", fields: [mergedIntoId], references: [id])
  mergedFrom      Story[]     @relation("StoryMerges")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  storySources   StorySource[]
  scoreSnapshots ScoreSnapshot[]

  @@index([marketId])
  @@index([compositeScore(sort: Desc)])
  @@index([status])
  @@index([firstSeenAt(sort: Desc)])
  @@index([breakingScore(sort: Desc)])
  @@index([trendingScore(sort: Desc)])
  @@index([category])
  @@index([status, compositeScore(sort: Desc)])
  @@index([marketId, status, compositeScore(sort: Desc)])
}

// ─── Story-Source Links ─────────────────────────────────────────────────────

model StorySource {
  id              String     @id @default(cuid())
  storyId         String
  story           Story      @relation(fields: [storyId], references: [id], onDelete: Cascade)
  sourcePostId    String
  sourcePost      SourcePost @relation(fields: [sourcePostId], references: [id], onDelete: Cascade)
  similarityScore Float
  isPrimary       Boolean    @default(false)
  addedAt         DateTime   @default(now())

  @@unique([storyId, sourcePostId])
  @@index([storyId])
  @@index([sourcePostId])
}

// ─── Score History ──────────────────────────────────────────────────────────

model ScoreSnapshot {
  id              String   @id @default(cuid())
  storyId         String
  story           Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  breakingScore   Float
  trendingScore   Float
  confidenceScore Float
  localityScore   Float
  compositeScore  Float
  snapshotAt      DateTime @default(now())

  @@index([storyId, snapshotAt(sort: Desc)])
}

// ─── RSS Feed Definitions ───────────────────────────────────────────────────

model RSSFeed {
  id        String   @id @default(cuid())
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String
  slug      String   @unique
  filters   Json
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
}

// ─── API Keys (for third-party consumers of OUR API) ────────────────────────

model APIKey {
  id          String    @id @default(cuid())
  accountId   String?
  account     Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  key         String    @unique
  name        String
  ownerId     String
  permissions Json?
  rateLimit   Int       @default(100)
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([key])
  @@index([accountId])
}

// ─── Audit Log ──────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  entityType  String
  entityId    String
  details     Json?
  createdAt   DateTime @default(now())

  @@index([accountId])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
}
