generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  // pgvector requires special PostgreSQL build — enable when available
  // extensions = [vector, pg_trgm]
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Platform {
  FACEBOOK
  TWITTER
  RSS
  NEWSAPI
  NEWSCATCHER
  PERIGON
  GDELT
  LLM_OPENAI
  LLM_CLAUDE
  LLM_GROK
  LLM_GEMINI
  MANUAL
}

enum SourceType {
  NEWS_ORG
  GOV_AGENCY
  PUBLIC_PAGE
  RSS_FEED
  API_PROVIDER
  LLM_PROVIDER
}

enum StoryStatus {
  ALERT       // Editor-confirmed, highest urgency — go live now
  BREAKING    // Auto-detected or editor-set breaking news
  DEVELOPING  // Story still gathering sources, could escalate
  TOP_STORY   // Biggest story of the cycle, high engagement
  ONGOING     // Multi-day story with continued interest
  FOLLOW_UP   // Update to a previously covered story
  STALE       // No meaningful activity
  ARCHIVED    // Terminal state
}

enum UserRole {
  VIEWER
  EDITOR
  ADMIN
  OWNER
}

// ─── Multi-Tenant: Account ─────────────────────────────────────────────────

model Account {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  isActive    Boolean  @default(true)
  plan        String   @default("free") // free, pro, enterprise
  maxMarkets  Int      @default(1)
  maxSources  Int      @default(20)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users          AccountUser[]
  markets        Market[]
  accountSources AccountSource[]
  credentials    AccountCredential[]
  apiKeys        APIKey[]
  feeds          RSSFeed[]
  coverageFeeds  CoverageFeed[]
  auditLogs      AuditLog[]

  @@index([slug])
  @@index([isActive])
}

// ─── Multi-Tenant: Users & Auth ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  displayName   String?
  avatarUrl     String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    AccountUser[]
  preferences UserPreference[]
  auditLogs   AuditLog[]

  @@index([email])
}

model AccountUser {
  id        String   @id @default(cuid())
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      UserRole @default(VIEWER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, userId])
  @@index([accountId])
  @@index([userId])
}

// ─── User Preferences (News Profile) ───────────────────────────────────────

model UserPreference {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId       String
  // News profile settings
  defaultMarketId String?  // preferred market to view on dashboard
  categories      Json?    // ["CRIME", "POLITICS", "WEATHER"] - preferred categories
  minScore        Float    @default(0) // minimum composite score filter
  keywords        Json?    // ["flooding", "energy"] - custom keywords of interest
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, accountId])
  @@index([accountId])
}

// ─── Multi-Tenant: Markets ──────────────────────────────────────────────────

model Market {
  id          String  @id @default(cuid())
  accountId   String
  account     Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name        String  // "Houston", "Dallas", "Austin"
  slug        String  // "houston", "dallas", "austin"
  state       String? // "TX"
  latitude    Float
  longitude   Float
  radiusKm    Float   @default(80)
  timezone    String  @default("America/Chicago")
  isActive    Boolean @default(true)
  // Market-specific keyword sets for filtering
  keywords    Json?   // ["houston", "harris county", "galveston"]
  neighborhoods Json? // ["Galleria", "Montrose", "Heights", ...]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sources Source[]
  stories Story[]

  @@unique([accountId, slug])
  @@index([accountId, isActive])
}

// ─── Multi-Tenant: Per-Account Credentials ──────────────────────────────────
// Each account stores their own API keys for external services

model AccountCredential {
  id          String   @id @default(cuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  platform    Platform
  name        String   // "NewsAPI Key", "OpenAI API Key", etc.
  // Encrypted credential fields
  apiKey      String?  @db.Text // encrypted at rest
  apiSecret   String?  @db.Text // encrypted at rest
  accessToken String?  @db.Text // encrypted at rest
  extraConfig Json?    // additional platform-specific config
  isActive    Boolean  @default(true)
  lastUsedAt  DateTime?
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([accountId, platform, name])
  @@index([accountId, platform])
}

// ─── Multi-Tenant: Account-Source Configuration ─────────────────────────────
// Controls which sources are enabled for each account

model AccountSource {
  id             String   @id @default(cuid())
  accountId      String
  account        Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sourceId       String
  source         Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  isEnabled      Boolean  @default(true)
  pollIntervalMs Int?     // override default poll interval
  metadata       Json?    // account-specific source config
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([accountId, sourceId])
  @@index([accountId, isEnabled])
}

// ─── Sources ────────────────────────────────────────────────────────────────

model Source {
  id           String       @id @default(cuid())
  platform     Platform
  sourceType   SourceType
  name         String
  url          String?
  platformId   String?
  trustScore   Float        @default(0.5)
  isActive     Boolean      @default(true)
  isGlobal     Boolean      @default(false) // available to all accounts
  marketId     String?
  market       Market?      @relation(fields: [marketId], references: [id], onDelete: SetNull)
  metadata     Json?
  lastPolledAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  posts          SourcePost[]
  accountSources AccountSource[]

  @@index([platform, isActive])
  @@index([sourceType])
  @@index([marketId])
  @@index([isGlobal])
}

// ─── Source Posts ────────────────────────────────────────────────────────────

model SourcePost {
  id                 String   @id @default(cuid())
  sourceId           String
  source             Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  platformPostId     String   @unique
  content            String   @db.Text
  contentHash        String
  title              String?
  url                String?
  authorName         String?
  authorId           String?
  engagementLikes    Int      @default(0)
  engagementShares   Int      @default(0)
  engagementComments Int      @default(0)
  latitude           Float?
  longitude          Float?
  locationName       String?
  category           String?
  mediaUrls          Json?
  rawData            Json?
  // LLM-specific fields
  llmModel           String?  // "gpt-4o", "claude-sonnet-4-6", "grok-3", "gemini-2.0-flash"
  llmConfidence      Float?   // LLM's self-reported confidence 0-1
  // Article extraction
  fullArticleText    String?  @db.Text  // extracted full article from URL
  fullArticleExtractedAt DateTime?
  // Embeddings (pgvector)
  // embedding stored as JSON until pgvector is available
  embeddingJson      Json?    // array of 1536 floats (upgrade to pgvector later)
  // NER entities (structured)
  entities           Json?    // { people: [], organizations: [], locations: [], events: [] }
  // Sentiment
  sentimentScore     Float?   // -1.0 (negative) to 1.0 (positive)
  sentimentLabel     String?  // POSITIVE, NEGATIVE, NEUTRAL
  // MinHash signature for LSH dedup
  minhashSignature   Json?    // array of hash values for LSH
  publishedAt        DateTime
  collectedAt        DateTime @default(now())
  createdAt          DateTime @default(now())

  storySources StorySource[]

  @@index([platformPostId])
  @@index([contentHash])
  @@index([sourceId, publishedAt])
  @@index([category])
  @@index([publishedAt])
  @@index([sentimentLabel])
}

// ─── Stories ────────────────────────────────────────────────────────────────

model Story {
  id              String      @id @default(cuid())
  marketId        String?
  market          Market?     @relation(fields: [marketId], references: [id], onDelete: SetNull)
  title           String
  summary         String?     @db.Text
  aiSummary       String?     @db.Text // LLM-generated canonical summary
  aiSummaryModel  String?     // which LLM generated the summary
  aiSummaryAt     DateTime?   // when summary was generated
  category        String?
  locationName    String?
  latitude        Float?
  longitude       Float?
  neighborhood    String?
  geocodedAt      DateTime?   // when geocoding was performed
  breakingScore   Float       @default(0)
  trendingScore   Float       @default(0)
  confidenceScore Float       @default(0)
  localityScore   Float       @default(0)
  compositeScore  Float       @default(0)
  // Sentiment aggregate
  sentimentScore  Float?      // avg sentiment across source posts
  sentimentLabel  String?     // POSITIVE, NEGATIVE, NEUTRAL, MIXED
  // Source credibility
  credibilityScore Float?     // auto-calculated from corroboration history
  // Editor review
  editedTitle     String?     // editor-modified title (null = use AI/original)
  editedSummary   String?     @db.Text // editor-modified summary
  editedBy        String?     // userId of last editor
  editedAt        DateTime?
  editHistory     Json?       // array of { title, summary, editedBy, editedAt }
  reviewStatus    String?     @default("UNREVIEWED") // UNREVIEWED, APPROVED, REJECTED, EDITED
  // Topic cluster (BERTopic)
  topicId         Int?        // BERTopic topic number
  topicLabel      String?     // human-readable topic label
  // Embedding for story-level similarity (JSON until pgvector available)
  embeddingJson   Json?
  status              StoryStatus @default(DEVELOPING)
  editorialOverride   Boolean     @default(false) // true = system scoring won't auto-change state
  statusChangedAt     DateTime    @default(now()) // explicit status change timestamp
  horizon             String      @default("BREAKING") // BREAKING or TRENDING — one-way latch
  parentStoryId       String?     // for FOLLOW_UP stories linking to original
  parentStory         Story?      @relation("StoryFollowUp", fields: [parentStoryId], references: [id])
  followUps           Story[]     @relation("StoryFollowUp")
  // Extended scoring fields
  longTrendingScore       Float?  // trending-horizon composite
  sustainedActivityScore  Float?  // how consistently new sources arrive
  peakBreakingScore       Float   @default(0)
  peakStatus              String?
  pastScores              Json?   // cached score snapshots at N-minutes-ago
  sourceCount     Int         @default(0)
  firstSeenAt     DateTime    @default(now())
  lastUpdatedAt   DateTime    @default(now())
  mergedIntoId    String?
  mergedInto      Story?      @relation("StoryMerges", fields: [mergedIntoId], references: [id])
  mergedFrom      Story[]     @relation("StoryMerges")
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  storySources       StorySource[]
  scoreSnapshots     ScoreSnapshot[]
  notifications      Notification[]
  coverageMatches    CoverageMatch[]
  stateTransitions   StoryStateTransition[]
  firstDrafts        FirstDraft[]
  bookmarks          Bookmark[]
  annotations        StoryAnnotation[]
  predictions        StoryPrediction[]

  @@index([marketId])
  @@index([compositeScore(sort: Desc)])
  @@index([status])
  @@index([firstSeenAt(sort: Desc)])
  @@index([breakingScore(sort: Desc)])
  @@index([trendingScore(sort: Desc)])
  @@index([category])
  @@index([status, compositeScore(sort: Desc)])
  @@index([marketId, status, compositeScore(sort: Desc)])
  @@index([horizon, compositeScore(sort: Desc)])
  @@index([statusChangedAt])
  @@index([parentStoryId])
}

// ─── Story-Source Links ─────────────────────────────────────────────────────

model StorySource {
  id              String     @id @default(cuid())
  storyId         String
  story           Story      @relation(fields: [storyId], references: [id], onDelete: Cascade)
  sourcePostId    String
  sourcePost      SourcePost @relation(fields: [sourcePostId], references: [id], onDelete: Cascade)
  similarityScore Float
  isPrimary       Boolean    @default(false)
  addedAt         DateTime   @default(now())

  @@unique([storyId, sourcePostId])
  @@index([storyId])
  @@index([sourcePostId])
}

// ─── Score History ──────────────────────────────────────────────────────────

model ScoreSnapshot {
  id              String   @id @default(cuid())
  storyId         String
  story           Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  breakingScore   Float
  trendingScore   Float
  confidenceScore Float
  localityScore   Float
  compositeScore  Float
  snapshotAt      DateTime @default(now())

  @@index([storyId, snapshotAt(sort: Desc)])
}

// ─── RSS Feed Definitions ───────────────────────────────────────────────────

model RSSFeed {
  id        String   @id @default(cuid())
  accountId String?
  account   Account? @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name      String
  slug      String   @unique
  filters   Json
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
}

// ─── API Keys (for third-party consumers of OUR API) ────────────────────────

model APIKey {
  id          String    @id @default(cuid())
  accountId   String?
  account     Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  key         String    @unique
  name        String
  ownerId     String
  permissions Json?
  rateLimit   Int       @default(100)
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([key])
  @@index([accountId])
}

// ─── Audit Log ──────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  accountId   String?
  account     Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String
  entityType  String
  entityId    String
  details     Json?
  createdAt   DateTime @default(now())

  @@index([accountId])
  @@index([entityType, entityId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

// ─── Notifications / Webhooks ───────────────────────────────────────────────

model Notification {
  id          String   @id @default(cuid())
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  type        String   // BREAKING_ALERT, TRENDING_ALERT, DIGEST
  channel     String   // EMAIL, WEBHOOK, SLACK
  recipient   String   // email address, webhook URL, or Slack channel
  payload     Json?    // notification content
  status      String   @default("PENDING") // PENDING, SENT, FAILED
  sentAt      DateTime?
  error       String?
  createdAt   DateTime @default(now())

  @@index([storyId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
}

model WebhookSubscription {
  id          String   @id @default(cuid())
  accountId   String
  name        String
  url         String   // webhook endpoint URL
  secret      String?  // HMAC signing secret
  events      Json     // ["BREAKING", "TRENDING", "NEW_STORY"]
  filters     Json?    // { category: "CRIME", minScore: 0.7 }
  isActive    Boolean  @default(true)
  lastDeliveredAt DateTime?
  failCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId, isActive])
}

// ─── Email Digest Subscriptions ─────────────────────────────────────────────

model DigestSubscription {
  id          String   @id @default(cuid())
  accountId   String
  userId      String
  email       String
  frequency   String   // HOURLY, TWICE_DAILY, DAILY, WEEKLY
  schedule    String?  // cron expression override
  timezone    String   @default("America/Chicago")
  filters     Json?    // { category: "CRIME", minScore: 0.5 }
  isActive    Boolean  @default(true)
  lastSentAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId])
  @@index([userId])
  @@index([frequency, isActive])
}

// ─── Source Credibility Tracking ────────────────────────────────────────────

model SourceCredibilityLog {
  id              String   @id @default(cuid())
  sourceId        String
  storyId         String
  wasCorroborated Boolean  // did other sources confirm this story?
  corroboratedBy  Int      @default(0) // how many other sources confirmed
  timeToCorroboration Int? // minutes until first corroboration
  createdAt       DateTime @default(now())

  @@index([sourceId])
  @@index([createdAt(sort: Desc)])
}

// ─── Topic Clusters (BERTopic) ──────────────────────────────────────────────

model TopicCluster {
  id          Int      @id // BERTopic topic number
  label       String   // auto-generated or admin-edited label
  keywords    Json     // top keywords for this topic
  storyCount  Int      @default(0)
  isActive    Boolean  @default(true)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive, storyCount(sort: Desc)])
}

// ─── Phase 1: Story State Transitions ──────────────────────────────────────

model StoryStateTransition {
  id          String      @id @default(cuid())
  storyId     String
  story       Story       @relation(fields: [storyId], references: [id], onDelete: Cascade)
  fromState   StoryStatus
  toState     StoryStatus
  trigger     String      // SYSTEM_SCORING, EDITOR_OVERRIDE, TIME_DECAY, GROK_ALERT
  triggeredBy String?     // userId if editor
  reason      String?
  metadata    Json?       // scoring data at time of transition
  createdAt   DateTime    @default(now())

  @@index([storyId, createdAt(sort: Desc)])
}

// ─── Phase 2: LLM Factory + FirstDraft + Prompts + Voices ──────────────────

model Prompt {
  id          String   @id @default(cuid())
  accountId   String?  // null = system default
  name        String   // "summary", "tweet", "rewrite", etc.
  type        String   // "first_draft", "idea_starter", "notification"
  template    String   @db.Text
  variables   Json     // list of available variables
  isDefault   Boolean  @default(false)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type, isDefault])
  @@index([accountId])
}

model FirstDraft {
  id          String   @id @default(cuid())
  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId      String?
  type        String   // summary, short_summary, rewrite, tweet, bullets, idea_starter
  voiceId     String?
  content     String   @db.Text
  model       String   // which LLM generated it
  promptId    String?
  tokens      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([storyId, type])
}

model Voice {
  id           String   @id @default(cuid())
  accountId    String
  name         String
  systemPrompt String   @db.Text
  sampleText   String?  @db.Text
  interests    Json?
  tone         Json?    // ["professional", "conversational"]
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([accountId])
}

// ─── Phase 3: CommunityRadar ───────────────────────────────────────────────

model CommunityRadarConfig {
  id                  String   @id @default(cuid())
  accountId           String
  name                String
  platform            Platform
  url                 String
  urlType             String   // FB_PAGE, FB_GROUP, TWITTER_LIST, TWITTER_SEARCH
  scrapeFrequencyMin  Int      @default(120)
  isActive            Boolean  @default(true)
  lastScrapedAt       DateTime?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  posts CommunityRadarPost[]

  @@index([accountId, isActive])
}

model CommunityRadarPost {
  id              String               @id @default(cuid())
  configId        String
  config          CommunityRadarConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  platformPostId  String               @unique
  content         String               @db.Text
  authorName      String?
  engagementScore Float                @default(0)
  sentimentScore  Float?
  sentimentLabel  String?
  storyId         String?
  postedAt        DateTime
  scrapedAt       DateTime             @default(now())

  @@index([configId])
  @@index([storyId])
}

// ─── Phase 4: Feature Flags ────────────────────────────────────────────────

model FeatureFlag {
  id           String   @id @default(cuid())
  name         String   @unique
  description  String?
  defaultValue Boolean  @default(false)
  overrides    Json?    // { accounts: { "acc1": true }, users: { "user1": false } }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Phase 5: Push Notifications + Distribution ────────────────────────────

model Device {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique // FCM token
  platform    String   // web, ios, android
  isActive    Boolean  @default(true)
  lastSeenAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
}

model NotificationPreference {
  id          String   @id @default(cuid())
  userId      String
  accountId   String
  channels    Json     // ["push", "email", "slack"]
  categories  Json?    // null = all
  minStates   Json     // ["ALERT", "BREAKING"]
  minScore    Float    @default(0.5)
  quietHours  Json?    // { start: "22:00", end: "07:00", timezone: "America/Chicago" }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, accountId])
}

model SlackIntegration {
  id          String   @id @default(cuid())
  accountId   String
  channelId   String
  channelName String
  webhookUrl  String
  states      Json     // which story states trigger
  categories  Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId, isActive])
}

// ─── Phase 6: Smart Pulses + Bookmarks + ShowPrep ──────────────────────────

model SmartPulse {
  id          String   @id @default(cuid())
  accountId   String
  userId      String?
  name        String
  description String?
  topics      Json     // keyword/semantic config
  filters     Json?    // category, market, min score
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  folder    String?
  tags      Json?
  notes     String?  @db.Text
  createdAt DateTime @default(now())

  @@unique([userId, storyId])
  @@index([userId])
}

model ShowPrepRundown {
  id        String   @id @default(cuid())
  accountId String
  createdBy String
  name      String
  showDate  DateTime
  items     Json     // ordered array of { storyId, notes, duration, talkingPoints }
  status    String   @default("DRAFT") // DRAFT, FINAL, ARCHIVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId, showDate(sort: Desc)])
}

// ─── Phase 7: Widgets + Analytics ──────────────────────────────────────────

model Widget {
  id        String   @id @default(cuid())
  accountId String
  name      String
  type      String   // PULSE, SMART_PULSE, CATEGORY, BREAKING
  config    Json     // theme, filters, display options
  embedCode String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
}

model StoryAnalytics {
  id          String   @id @default(cuid())
  storyId     String
  views       Int      @default(0)
  apiHits     Int      @default(0)
  widgetViews Int      @default(0)
  shares      Int      @default(0)
  date        DateTime @db.Date
  createdAt   DateTime @default(now())

  @@unique([storyId, date])
}

model DomainScore {
  id          String   @id @default(cuid())
  domain      String   @unique
  score       Float    @default(0)
  appearances Int      @default(0)
  lastUpdated DateTime @default(now())
}

// ─── Collaborative Annotations ─────────────────────────────────────────────

model StoryAnnotation {
  id        String   @id @default(cuid())
  storyId   String
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  userId    String
  type      String   @default("NOTE") // NOTE, TAG, FLAG, ASSIGNMENT
  content   String   @db.Text
  tags      Json?    // e.g. ["urgent", "needs-followup"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storyId, createdAt(sort: Desc)])
  @@index([userId])
}

// ─── Story Prediction Scoring ──────────────────────────────────────────────

model StoryPrediction {
  id              String   @id @default(cuid())
  storyId         String
  story           Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  viralProbability Float   // 0-1 probability of going viral
  peakScorePrediction Float? // predicted peak composite score
  predictedStatus String?  // predicted final status
  factors         Json?    // { velocityTrend, sourceDiversity, engagement, ... }
  model           String   @default("heuristic_v1")
  createdAt       DateTime @default(now())

  @@index([storyId, createdAt(sort: Desc)])
}

// ─── Audio Transcription ───────────────────────────────────────────────────

model AudioSource {
  id            String   @id @default(cuid())
  accountId     String
  name          String   // "Police Scanner Feed", "Press Conference"
  type          String   // STREAM, FILE, URL
  url           String?
  isActive      Boolean  @default(true)
  lastProcessedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  transcripts AudioTranscript[]

  @@index([accountId, isActive])
}

model AudioTranscript {
  id            String       @id @default(cuid())
  audioSourceId String
  audioSource   AudioSource  @relation(fields: [audioSourceId], references: [id], onDelete: Cascade)
  content       String       @db.Text
  duration      Int?         // seconds
  language      String       @default("en")
  confidence    Float?       // transcription confidence 0-1
  storyId       String?      // linked story if matched
  processedAt   DateTime     @default(now())

  @@index([audioSourceId, processedAt(sort: Desc)])
  @@index([storyId])
}

// ─── Dashboard Layouts per Role ────────────────────────────────────────────

model DashboardLayout {
  id          String   @id @default(cuid())
  accountId   String
  name        String   // "Anchor View", "Assignment Editor", "Producer"
  role        String?  // optional: lock to a specific UserRole
  layout      Json     // { panels: [{ type, position, size, config }] }
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId])
}

// ─── Coverage Gap Detection ────────────────────────────────────────────────
// Tracks what stories an account's newsroom has already covered vs missed.

model CoverageFeed {
  id              String   @id @default(cuid())
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  name            String   // "Our CMS RSS", "Station Website", etc.
  type            String   // RSS, API, SCRAPE
  url             String   // Feed URL, API endpoint, or page to scrape
  authConfig      Json?    // Optional auth: { apiKey, headers, cookies }
  pollIntervalMin Int      @default(15) // How often to check (minutes)
  cssSelector     String?  // For SCRAPE type: CSS selector for article links
  isActive        Boolean  @default(true)
  lastPolledAt    DateTime?
  lastError       String?
  itemCount       Int      @default(0) // Total items fetched
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  matches CoverageMatch[]

  @@index([accountId, isActive])
}

model CoverageMatch {
  id              String   @id @default(cuid())
  coverageFeedId  String
  coverageFeed    CoverageFeed @relation(fields: [coverageFeedId], references: [id], onDelete: Cascade)
  storyId         String
  story           Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  accountId       String
  // What matched from their feed
  matchedUrl      String?
  matchedTitle    String?
  similarityScore Float    // 0-1 Jaccard similarity
  isCovered       Boolean  // true = they covered it, false = gap
  matchedAt       DateTime @default(now())

  @@unique([coverageFeedId, storyId])
  @@index([accountId, isCovered])
  @@index([storyId])
}
